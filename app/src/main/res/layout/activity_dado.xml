<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F272F"
    android:gravity="start"
    android:orientation="vertical"
    android:padding="20dp">

    <Button
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="&lt;"
        android:id="@+id/btnVolver"
        android:textSize="20dp"
        android:textStyle="bold"
        android:backgroundTint="#F8CE36"/>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#0F272F"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="20dp">



        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tirada de Suerte"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="40dp"/>

        <ImageView
            android:id="@+id/imgDado"
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:src="@drawable/role_play_dice_icon"
            android:layout_marginBottom="20dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/txtResultadoDado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="¡Toca el dado para lanzar!"
            android:textColor="#B0BEC5"
            android:textSize="20sp"
            android:textAlignment="center"
            android:layout_marginTop="10dp"/>
    </LinearLayout>
</LinearLayout>